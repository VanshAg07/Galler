# Backend — copy to server/.env for local development
FRONTEND_URL=http://localhost:3000
JWT_SECRET=change-me-in-production

# Resend (optional until domain is verified — subscribers are still saved without this)
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_TO_EMAIL=you@example.com
# CONTACT_FROM_EMAIL=Galler Website <onboarding@resend.dev>
# NEWSLETTER_FROM_EMAIL=Galler Website <onboarding@resend.dev>

# Production (Render dashboard): set FRONTEND_URL to your Vercel URL
# FRONTEND_URL=https://your-frontend.vercel.app
